# 应用配置
APP_NAME=FastAPI Enterprise
APP_VERSION=1.0.0
APP_DESCRIPTION=FastAPI企业级框架
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
APP_API_V1_STR=/api/v1

# CORS配置
APP_CORS_ORIGINS=["*"]
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_ALLOW_METHODS=["*"]
APP_CORS_ALLOW_HEADERS=["*"]

# JWT配置
APP_SECRET_KEY=your-secret-key
APP_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30

# SQLite数据库配置
SQLITE_DATABASE=fastapi_enterprise
SQLITE_DATABASE_FILE=app.db
SQLITE_ECHO_SQL=false

# 日志配置
LOGGING_LEVEL=INFO
LOGGING_FILE=logs/app.log
LOGGING_MAX_BYTES=10485760
LOGGING_BACKUP_COUNT=5
